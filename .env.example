# EcommerceSaaS Environment Variables

## BACKEND

# Database
CONNECTION_STRING=Host=localhost;Port=5432;Database=ecommerce_saas;Username=postgres;Password=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-key-min-32-characters-long-for-hs256
JWT_ISSUER=EcommerceSaaS
JWT_AUDIENCE=EcommerceSaaSUsers
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=Information

# Features
ENABLE_SWAGGER=true
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1

## FRONTEND

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENV=development

# Feature Flags
REACT_APP_ENABLE_VENDOR_FEATURES=true
REACT_APP_ENABLE_ADMIN_FEATURES=true

## PAYMENT (Optional)

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# Razorpay
RAZORPAY_KEY_ID=your_key_id

## EMAIL (Optional)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

## STORAGE (Optional)

# AWS S3
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=ecommerce-saas-files
AWS_REGION=us-east-1
